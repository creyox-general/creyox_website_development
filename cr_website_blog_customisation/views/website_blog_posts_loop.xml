<!--            </div>-->
<!--        </xpath>-->
<!--    </template>-->

    <template id="custom_blog_post_content" inherit_id="website_blog.blog_post_content">
        <xpath expr="//t[@t-call='website_blog.post_breadcrumbs']" position="replace"/>
        <xpath expr="//div[@t-if='len(blogs) > 1 or len(blog_post.tag_ids) > 0']" position="replace"/>
    </template>


</odoo>




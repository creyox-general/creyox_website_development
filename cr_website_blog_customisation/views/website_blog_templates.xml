<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="blog_post_short_without_top" name="Blog Posts without Top Section" inherit_id="website_blog.blog_post_short">
        <xpath expr="//div[@id='o_wblog_blog_top']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//t[@t-call='website.pager']" position="attributes">
            <attribute name="t-if">is_pager</attribute>
        </xpath>
    </template>

    <!-- Blog Intro Banner Implementation -->
    <template id="blog_post_header" inherit_id="website_blog.blog_post_complete" name="Blog Post Header">
        <xpath expr="//section[@id='o_wblog_post_top']" position="replace">
            <t t-call="cr_website_blog_customisation.s_blog_intro_banner">
                <t t-set="blog" t-value="blog_post"/>
            </t>
        </xpath>
    </template>
</odoo>
<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_blog_post_form_inherit" model="ir.ui.view">
        <field name="name">blog.post.form.inherit</field>
        <field name="model">blog.post</field>
        <field name="inherit_id" ref="website_blog.view_blog_post_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='blog_details']" position="inside">
                <field name="short_title"/>
                <field name="color"/>
                <field name="background_color" widget="color"/>
            </xpath>
        </field>
    </record>


    <record id="blog_tag_tree_inherit" model="ir.ui.view">
        <field name="name">blog_tag_tree_inherit</field>
        <field name="model">blog.tag</field>
        <field name="inherit_id" ref="website_blog.blog_tag_tree"/> <!-- Inherit the original tree view -->
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="active"/>
            </xpath>
        </field>
    </record>

    <record id="blog_tag_form_inherit" model="ir.ui.view">
        <field name="name">blog_tag_form_inherit</field>
        <field name="model">blog.tag</field>
        <field name="inherit_id" ref="website_blog.blog_tag_form"/> <!-- Inherit the original form view -->
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="active"/>
            </xpath>
        </field>
    </record>

</odoo>



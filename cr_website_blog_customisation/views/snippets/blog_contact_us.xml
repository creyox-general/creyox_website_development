<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template for the Blog Contact Us Sidebar Snippet HTML structure -->
    <template id="s_blog_contact_us" name="Blog Contact Us Sidebar">
        <section class="s_blog_contact_us oe_structure_not_nearest" data-name="Blog Contact Us Sidebar">
            <div class="cr-blog-contact-sidebar">
                <div class="cr-contact-icon-wrap">
                    <i class="fa fa-paper-plane cr-contact-icon"></i>
                </div>
                <div class="cr-contact-title">Need Expert Help?</div>
                <p class="cr-contact-text">
                    Speak with our payment integration and custom software development specialists today!
                </p>
                <div class="cr-contact-info-list">
                    <div class="cr-contact-info-item">
                        <i class="fa fa-envelope"></i>
                        <span>sales@creyox.com</span>
                    </div>
                    <div class="cr-contact-info-item">
                        <i class="fa fa-phone"></i>
                        <span>+1 (888) 998-0720</span>
                    </div>
                </div>
                <a href="/contactus" class="btn cr-contact-btn w-100">
                    Get Free Consultation
                </a>
            </div>
        </section>
    </template>

    <!-- Custom Snippet Options for the Blog Contact Us Widget -->
    <template id="s_blog_contact_us_options" inherit_id="website.snippet_options" name="Blog Contact Us Options">
        <xpath expr="." position="inside">
            <!-- Target the Contact Us snippet container class and modify the inner sidebar design -->
            <div data-selector=".s_blog_contact_us" data-target=".cr-blog-contact-sidebar">
                <we-select string="Background Theme">
                    <we-button string="Glassmorphic Light (Default)" data-select-class=""/>
                    <we-button string="Glassmorphic Dark" data-select-class="bg-glass-dark"/>
                    <we-button string="Clean Flat White" data-select-class="bg-flat-clean"/>
                    <we-button string="Dashed Outline Only" data-select-class="bg-outline-only"/>
                </we-select>
                <we-select string="Title Alignment">
                    <we-button string="Left" data-select-class=""/>
                    <we-button string="Center" data-select-class="title-center"/>
                    <we-button string="Right" data-select-class="title-right"/>
                </we-select>
            </div>
        </xpath>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template for the Blog Table of Contents Snippet HTML structure -->
    <template id="s_blog_toc" name="Blog Table of Contents">
        <section class="s_blog_toc oe_structure_not_nearest" data-name="Blog Table of Contents">
            <div class="cr-blog-toc-sidebar">
                <div class="cr-toc-title">On This Page</div>
                
                <!-- Dynamic Automatic Outline (Locked against accidental overrides) -->
                <ul class="cr-toc-list o_not_editable">
                    <!-- Dynamically populated and scrolled-spy by JQuery Widget -->
                </ul>
            </div>
        </section>
    </template>

    <!-- Custom Snippet Options for the Blog Table of Contents Widget -->
    <template id="s_blog_toc_options" inherit_id="website.snippet_options" name="Blog TOC Options">
        <xpath expr="." position="inside">
            <!-- Target the Table of Contents snippet container class and modify the inner sidebar design -->
            <div data-selector=".s_blog_toc" data-target=".cr-blog-toc-sidebar">
                <we-select string="Background Theme">
                    <we-button string="Glassmorphic Light (Default)" data-select-class=""/>
                    <we-button string="Glassmorphic Dark" data-select-class="bg-glass-dark"/>
                    <we-button string="Clean Flat White" data-select-class="bg-flat-clean"/>
                    <we-button string="Dashed Outline Only" data-select-class="bg-outline-only"/>
                </we-select>
                <we-select string="Display Hierarchy">
                    <we-button string="Accordion Folding" data-select-class=""/>
                    <we-button string="Main Topics Only" data-select-class="mode-main-only"/>
                    <we-button string="Show All Expanded" data-select-class="mode-fully-expanded"/>
                </we-select>
                <we-select string="Title Alignment">
                    <we-button string="Left" data-select-class=""/>
                    <we-button string="Center" data-select-class="title-center"/>
                    <we-button string="Right" data-select-class="title-right"/>
                </we-select>
            </div>
        </xpath>
    </template>
</odoo>

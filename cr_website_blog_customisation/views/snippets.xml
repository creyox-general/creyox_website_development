<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="custom_snippets" inherit_id="website.snippets" name="Custom Snippets">
        <xpath expr="//div[@id='snippet_structure']" position="before">
            <div id="snippet_structure" class="o_panel">
                <div class="o_panel_header">Creyox</div>
                <div class="o_panel_body">
                    <t t-snippet="cr_website_blog_customisation.cr_random_blogs"
                       t-thumbnail="/cr_website_blog_customisation/static/src/img/snippets/random-blogs.svg">
                        <keywords>explore, clients</keywords>
                    </t>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
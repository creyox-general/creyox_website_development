<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="case_study_page" name="Case Studies">
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row">
                    <t t-foreach="case_studies" t-as="case">
                        <div class="col-md-4 mb-4">
                            <div class="card shadow-sm">
                                <img t-att-src="case['case_study_main_page_banner']" class="card-img-top" style="height: 200px; object-fit: cover;"/>
                                <div class="card-body">
                                    <h5 class="card-title" t-esc="case['case_study_name']"/>
                                    <p class="card-text" t-raw="case['case_study_short_description']"/>
                                </div>
                                <div class="card-footer text-center">
                                    <a t-att-href="'/case_study/%s' % case['id']" class="btn btn-primary">View</a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>


</odoo>

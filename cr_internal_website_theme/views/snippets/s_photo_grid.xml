<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_photo_grid" name="Photo Grid Section">
        <section id="life_at_creyox" class="s_photo_grid bg-white" data-snippet="s_photo_grid">
            <div class="container">
                <div class="section_header text-center mb-5" data-aos="fade-up">
                    <h2 class="display-5 fw-bold text-primary">Life at Creyox</h2>
                    <p class="lead text-muted mx-auto" style="max-width: 800px;">Experience a highly energetic culture where career goals meet limitless innovation, learning, and celebration.</p>
                </div>
                
                <div class="row g-4 photo_gallery_grid">
                    <!-- Row 1: 4 + 8 -->
                    <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="photo_item_v2">
                            <img src="/cr_internal_website_theme/static/src/img/career_team.png" alt="Collaborative Culture" class="img-fluid rounded-4 shadow-sm w-100"/>
                            <div class="photo_overlay">
                                <h3>Collaborative Culture</h3>
                                <p>Synergy that makes work exciting.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-8" data-aos="fade-up" data-aos-delay="200">
                        <div class="photo_item_v2">
                            <img src="/cr_internal_website_theme/static/src/img/office_team_working_premium.png" alt="Vibrant Workspace" class="img-fluid rounded-4 shadow-sm w-100"/>
                            <div class="photo_overlay">
                                <h3>Vibrant Workspace</h3>
                                <p>State-of-the-art office designed for productivity.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2: 4 + 4 + 4 -->
                    <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                        <div class="photo_item_v2">
                            <img src="/cr_internal_website_theme/static/src/img/odoo_consulting_workshop.png" alt="Continuous Learning" class="img-fluid rounded-4 shadow-sm w-100"/>
                            <div class="photo_overlay">
                                <h3>Continuous Learning</h3>
                                <p>Comprehensive Odoo workshops and certification paths.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4" data-aos="fade-up" data-aos-delay="400">
                        <div class="photo_item_v2">
                            <img src="/cr_internal_website_theme/static/src/img/odoo_process_mapping.png" alt="Impactful Projects" class="img-fluid rounded-4 shadow-sm w-100"/>
                            <div class="photo_overlay">
                                <h3>Impactful Projects</h3>
                                <p>Designing robust workflows for global enterprises.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4" data-aos="fade-up" data-aos-delay="500">
                        <div class="photo_item_v2">
                            <img src="/cr_internal_website_theme/static/src/img/growth_image.png" alt="Unlimited Growth" class="img-fluid rounded-4 shadow-sm w-100"/>
                            <div class="photo_overlay">
                                <h3>Unlimited Growth</h3>
                                <p>Fast-track your development in a supportive environment.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Row 3: 8 + 4 -->
                    <div class="col-md-8" data-aos="fade-up" data-aos-delay="600">
                        <div class="photo_item_v2">
                            <img src="/cr_internal_website_theme/static/src/img/odoo_consulting_expert.png" alt="Work with Experts" class="img-fluid rounded-4 shadow-sm w-100"/>
                            <div class="photo_overlay">
                                <h3>Work with Experts</h3>
                                <p>Collaborate with senior developers and certified Odoo architects.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4" data-aos="fade-up" data-aos-delay="700">
                        <div class="photo_item_v2">
                            <img src="/cr_internal_website_theme/static/src/img/odoo-dev-intro.png" alt="Cutting-Edge Tech" class="img-fluid rounded-4 shadow-sm w-100"/>
                            <div class="photo_overlay">
                                <h3>Cutting-Edge Tech</h3>
                                <p>Build next-gen Python, JS, and Odoo products.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>

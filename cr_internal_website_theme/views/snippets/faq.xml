    <!-- SNIPPET OPTIONS -->
    <template id="faq_snippet_options" inherit_id="website.snippet_options">
        <xpath expr="." position="inside">
            <div data-selector=".s_faq_dynamic" data-js="FaqLayoutOptions" string="FAQ">
                <we-select string="Layout" data-no-preview="true">
                    <we-button string="Accordion" data-set-faq-layout="o_faq_template_1"/>
                    <we-button string="Grid" data-set-faq-layout="o_faq_template_2"/>
                    <we-button string="Numbered" data-set-faq-layout="o_faq_template_3"/>
                    <we-button string="Split" data-set-faq-layout="o_faq_template_4"/>
                    <we-button string="Minimal" data-set-faq-layout="o_faq_template_5"/>
                </we-select>
            </div>
        </xpath>
    </template>

</odoo>
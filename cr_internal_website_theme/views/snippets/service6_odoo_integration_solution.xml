                    <section class="cr-prebuilt-integrations" aria-labelledby="prebuilt-integrations-heading">
  <div class="cr-odoo-container">
    <h2 id="prebuilt-integrations-heading">Pre-Built Integration Solutions</h2>
    <p class="section-intro">
      Accelerate your business with our ready-to-deploy Odoo integration connectors —
      purpose-built to simplify data flow, enhance automation, and connect Odoo with world-class platforms.
    </p>

    <div class="integration-cards-grid">

      <!-- 3CX CRM Connector -->
      <div class="integration-card">
        <div class="integration-card-header">
          <i class="fas fa-phone-volume"></i>
          <h3><a href="https://apps.odoo.com/apps/modules/19.0/cr_3cx_crm_connector" target="_blank">3CX CRM Connector</a></h3>
        </div>
        <p>Enable seamless telephony integration between Odoo and 3CX for advanced call management.</p>
        <ul class="integration-features-list">
          <li>Click-to-call and call popups in Odoo</li>
          <li>Auto-create leads from incoming calls</li>
          <li>Track communication history inside CRM</li>
        </ul>
      </div>

      <!-- TikTok Shop Connector -->
      <div class="integration-card">
        <div class="integration-card-header">
          <i class="fab fa-tiktok"></i>
          <h3><a href="https://apps.odoo.com/apps/modules/19.0/cr_tiktok_shop_connector" target="_blank">TikTok Shop Connector</a></h3>
        </div>
        <p>Connect your TikTok Shop with Odoo for unified product, order, and inventory synchronization.</p>
        <ul class="integration-features-list">
          <li>Automatic product and order sync</li>
          <li>Inventory updates in real time</li>
          <li>Centralized TikTok analytics in Odoo</li>
        </ul>
      </div>

      <!-- BigQuery Connector -->
      <div class="integration-card">
        <div class="integration-card-header">
          <i class="fas fa-database"></i>
          <h3><a href="https://apps.odoo.com/apps/modules/19.0/cr_bigquery_connector" target="_blank">BigQuery Connector</a></h3>
        </div>
        <p>Send your Odoo data directly to Google BigQuery for large-scale analytics and visualization.</p>
        <ul class="integration-features-list">
          <li>Data export automation to BigQuery</li>
          <li>Supports custom models and filters</li>
          <li>Perfect for advanced BI workflows</li>
        </ul>
      </div>

      <!-- Power BI Desktop Connector -->
      <div class="integration-card">
        <div class="integration-card-header">
          <i class="fas fa-chart-line"></i>
          <h3><a href="https://apps.odoo.com/apps/modules/19.0/cr_power_bi_desktop_connector" target="_blank">Power BI Desktop Connector</a></h3>
        </div>
        <p>Empower business decisions with direct, real-time Power BI data connectivity from Odoo.</p>
        <ul class="integration-features-list">
          <li>Direct Power BI data connection</li>
          <li>Scheduled synchronization</li>
          <li>Live dashboards with Odoo KPIs</li>
        </ul>
      </div>

      <!-- Odoo to Sheets Connector -->
      <div class="integration-card">
        <div class="integration-card-header">
          <i class="fab fa-google"></i>
          <h3><a href="https://apps.odoo.com/apps/modules/19.0/cr_odoo_to_sheets_connector" target="_blank">Odoo to Sheets Connector</a></h3>
        </div>
        <p>Export live Odoo data to Google Sheets with ease — perfect for teams using collaborative analytics.</p>
        <ul class="integration-features-list">
          <li>Real-time data sync with Sheets</li>
          <li>Customizable export fields</li>
          <li>Auto-refresh and scheduled updates</li>
        </ul>
      </div>

      <!-- Brevo (Sendinblue) Integration -->
      <div class="integration-card">
        <div class="integration-card-header">
          <i class="fas fa-envelope-open-text"></i>
          <h3><a href="https://apps.odoo.com/apps/modules/19.0/cr_odoo_brevo_integratio" target="_blank">Odoo Brevo Integration</a></h3>
        </div>
        <p>Connect Odoo with Brevo (Sendinblue) for email marketing, automation, and customer engagement.</p>
        <ul class="integration-features-list">
          <li>Sync Odoo contacts to Brevo lists</li>
          <li>Automated campaign triggers</li>
          <li>Email tracking and analytics</li>
        </ul>
      </div>

    </div>
  </div>
</section>


<!-- 3. Integration Flow Diagram Section -->
<section class="cr-integration-flow" aria-labelledby="integration-flow-heading">
    <div class="cr-odoo-container">
        <h2 id="integration-flow-heading">How Our Integration Process Works</h2>
        <p class="section-intro">
            A systematic, proven approach to ensure seamless integration with minimal disruption to your business operations.
        </p>

        <div class="flow-diagram">
            <div class="flow-step">
                <div class="flow-step-number">1</div>
                <div class="flow-step-content">
                    <h3>Discovery &amp; Analysis</h3>
                    <p>We analyze your current systems, understand business requirements, and identify integration touchpoints.</p>
                </div>
            </div>

            <div class="flow-connector"></div>

            <div class="flow-step">
                <div class="flow-step-number">2</div>
                <div class="flow-step-content">
                    <h3>Architecture Design</h3>
                    <p>Design scalable integration architecture with proper data mapping, security protocols, and error handling.</p>
                </div>
            </div>

            <div class="flow-connector"></div>

            <div class="flow-step">
                <div class="flow-step-number">3</div>
                <div class="flow-step-content">
                    <h3>Development &amp; Testing</h3>
                    <p>Build custom connectors, implement APIs, and conduct rigorous testing in a sandbox environment.</p>
                </div>
            </div>

            <div class="flow-connector"></div>

            <div class="flow-step">
                <div class="flow-step-number">4</div>
                <div class="flow-step-content">
                    <h3>Deployment &amp; Migration</h3>
                    <p>Deploy to production with careful data migration, validation checks, and rollback plans.</p>
                </div>
            </div>

            <div class="flow-connector"></div>

            <div class="flow-step">
                <div class="flow-step-number">5</div>
                <div class="flow-step-content">
                    <h3>Training &amp; Documentation</h3>
                    <p>Provide comprehensive training and detailed documentation for your team members.</p>
                </div>
            </div>

            <div class="flow-connector"></div>

            <div class="flow-step">
                <div class="flow-step-number">6</div>
                <div class="flow-step-content">
                    <h3>Monitoring &amp; Support</h3>
                    <p>Continuous monitoring, performance optimization, and ongoing technical support.</p>
                </div>
            </div>
        </div>
    </div>
</section>


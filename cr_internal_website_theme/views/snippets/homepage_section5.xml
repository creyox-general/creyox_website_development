<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="homepage_section5" name="Why Choose Us">
        <div class="oe_structure" id="oe_structure_why_choose_us_1">
            <section class="s_why_choose_us cr_font" data-snippet="s_why_choose_us" data-name="Why Choose Us">
                <!-- Background Premium Elements -->
                <div class="bg-mesh"></div>
                <div class="bg-orb orb-1"></div>
                <div class="bg-orb orb-2"></div>
                <div class="decorative-particle p1">+</div>
                <div class="decorative-particle p2">+</div>

                <div class="container">
                    <!-- Professional Top Heading -->
                    <div class="section-header mb-5 text-center mx-auto" data-aos="fade-down" style="max-width: 900px;">
                        <h2 class="section-title">
                                Why Businesses Choose
                                <span class="text-gradient">Creyox Technologies</span>
                        </h2>
                        <div class="title-underline mx-auto"></div>
                        <p class="section-description mt-4 text-center">
                            Delivering high-end Odoo ERP experiences with a focus on AI innovation, global scalability, and measurable ROI across industries.
                        </p>
                    </div>

                    <!-- Matching Visual Mosaic (4 Images) -->
                    <div class="solution-mosaic">
                        <div class="row g-4">
                            <!-- Row 1: AI (8) and Image (4) -->
                            <div class="col-lg-8" data-aos="fade-right">
                                <div class="stack-card card-blue h-100">
                                    <span class="card-number">01</span>
                                    <div class="card-icon-inner">
                                        <i class="fas fa-robot"/>
                                    </div>
                                    <h3 class="card-title">AI-First Approach</h3>
                                    <p class="card-text">We integrate advanced AI automation and predictive analytics directly into your Odoo core, transforming how you handle data and customer interactions.</p>
                                </div>
                            </div>
                            <div class="col-lg-4" data-aos="fade-left">
                                <div class="mosaic-image-block" style="background-image: url('/cr_internal_website_theme/static/src/img/ai_erp_dashboard_premium.png');"></div>
                            </div>

                            <!-- Row 2: Cloud Card (4), Cloud Image (4), Odoo Stack Card (4) -->
                            <div class="col-lg-4 col-md-6" data-aos="fade-up">
                                <div class="stack-card card-white h-100">
                                    <span class="card-number">02</span>
                                    <div class="card-icon-inner">
                                        <i class="fas fa-cloud"/>
                                    </div>
                                    <h3 class="card-title">Cloud-Native</h3>
                                    <p class="card-text">Secure, mobile-ready cloud infrastructure that scales with your business growth while ensuring maximum uptime and accessibility.</p>
                                </div>
                            </div>
                            <div class="col-lg-4 d-none d-lg-block" data-aos="zoom-in">
                                <div class="mosaic-image-block" style="background-image: url('/cr_internal_website_theme/static/src/img/odoo_stack_v3_premium.png');"></div>
                            </div>
                            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                                <div class="stack-card card-dark h-100">
                                    <span class="card-number">03</span>
                                    <div class="card-icon-inner">
                                        <i class="fas fa-layer-group"/>
                                    </div>
                                    <h3 class="card-title">Full Odoo Stack</h3>
                                    <p class="card-text">Comprehensive implementation, custom development, and seamless integration of all Odoo modules to automate your entire operation.</p>
                                </div>
                            </div>

                            <!-- Row 3: Odoo Stack Image (4), Industry Card (4), Team Image (4) -->
                            <div class="col-lg-4" data-aos="fade-right">
                                <div class="mosaic-image-block" style="background-image: url('/cr_internal_website_theme/static/src/img/odoo_stack_premium.png');"></div>
                            </div>
                            <div class="col-lg-4" data-aos="fade-up">
                                <div class="stack-card card-white h-100">
                                    <span class="card-number">04</span>
                                    <div class="card-icon-inner">
                                        <i class="fas fa-building"/>
                                    </div>
                                    <h3 class="card-title">Industry Expertise</h3>
                                    <p class="card-text">Tailored Odoo solutions for manufacturing, retail, healthcare, and logistics, built by experts who understand your unique business challenges.</p>
                                </div>
                            </div>
                            <div class="col-lg-4 d-none d-lg-block" data-aos="fade-left">
                                <div class="mosaic-image-block" style="background-image: url('/cr_internal_website_theme/static/src/img/office_team_working_premium.png');"></div>
                            </div>

                            <!-- Row 4: Support (6) and ROI (6) -->
                            <div class="col-lg-6" data-aos="fade-up">
                                <div class="stack-card card-blue h-100">
                                    <span class="card-number">05</span>
                                    <div class="card-icon-inner">
                                        <i class="fas fa-headset"/>
                                    </div>
                                    <h3 class="card-title">Dedicated Support</h3>
                                    <p class="card-text">Our commitment to your success continues after launch with 24/7 monitoring, proactive maintenance, and instant troubleshooting.</p>
                                </div>
                            </div>
                            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="100">
                                <div class="stack-card card-dark h-100">
                                    <span class="card-number">06</span>
                                    <div class="card-icon-inner">
                                        <i class="fas fa-chart-line"/>
                                    </div>
                                    <h3 class="card-title">ROI-Focused Delivery</h3>
                                    <p class="card-text">We focus on high-impact implementations that deliver fast ROI and measurable efficiency gains, ensuring your investment pays off quickly.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </template>
</odoo>

                                    <h3 class="card-title">Solution Design</h3>
                                    <p class="card-desc">Translating requirements into a technical blueprint. We design customized Odoo architecture aligned with your business.</p>
                                </div>
                            </div>
                        </div>

                        <!-- Row 2 -->
                        <div class="row g-4 s_kinetic_row_2">
                            <!-- Phase 3 -->
                            <div class="col-lg-4 phase-block" data-aos="fade-up" data-aos-delay="200">

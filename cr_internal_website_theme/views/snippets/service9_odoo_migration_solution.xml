                                <div class="process-box image-box">
                                    <img src="/cr_internal_website_theme/static/src/img/step-launch.png" alt="Go Live"/>
                                </div>
                                <div class="process-box content-box">
                                    <h3>Step 5: Go Live &amp; Support</h3>

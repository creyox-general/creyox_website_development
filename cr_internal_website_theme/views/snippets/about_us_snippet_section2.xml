<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="about_us_snippet_section2" name="AboutUS Section-2">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

        <!-- Active Specialist Grid Section (Vision, Mission & Values Variant) -->
        <section class="s_specialist_grid vvm-milestone-style-section cr_font" 
                 data-snippet="s_specialist_grid" 
                 data-name="Specialist Grid"
                 aria-labelledby="vvm-heading">
            <div class="milestone-wrapper container">
                
                <!-- Section Header (hidden placeholders to keep SpecialistGridOptions JS completely happy) -->
                <div class="section-header text-center d-none">
                    <h2 class="section-title">Vision, <span class="text-gradient">Mission &amp; Values</span></h2>
                    <p class="section-subtitle mt-2">Space-efficient expertise at your fingertips.</p>
                </div>

                <h2 id="vvm-heading" class="milestone-heading" data-aos="fade-up">Vision, Mission &amp; Values</h2>
                
                <div class="milestone-grid s_specialist_grid_row" role="list">
                    
                    <!-- Card 1 -->
                    <div class="s_specialist_card_col" style="--i:1" role="listitem" data-aos="fade-up" data-aos-delay="100">
                        <div class="milestone-card specialist-card">
                            <div class="milestone-icon" aria-hidden="true">
                                <i class="fas fa-eye"></i>
                            </div>
                            <h3 class="card-title">Our Vision</h3>
                            <p class="card-text">
                                Delivering intelligent ERP solutions that redefine operational excellence and enable sustainable growth.
                            </p>
                        </div>
                    </div>
                    
                    <!-- Card 2 -->
                    <div class="s_specialist_card_col" style="--i:2" role="listitem" data-aos="fade-up" data-aos-delay="200">
                        <div class="milestone-card specialist-card">
                            <div class="milestone-icon" aria-hidden="true">
                                <i class="fas fa-bullseye"></i>
                            </div>
                            <h3 class="card-title">Our Mission</h3>
                            <p class="card-text">
                                Empower businesses by crafting tailored Odoo experiences, merging innovation, and strategy to drive impactful results.
                            </p>
                        </div>
                    </div>
                    
                    <!-- Card 3 -->
                    <div class="s_specialist_card_col" style="--i:3" role="listitem" data-aos="fade-up" data-aos-delay="300">
                        <div class="milestone-card specialist-card">
                            <div class="milestone-icon" aria-hidden="true">
                                <i class="fas fa-heart"></i>
                            </div>
                            <h3 class="card-title">Our Core Values</h3>
                            <p class="card-text">
                                Customer-first mindset. We uphold these pillars in every solution we design and deliver.
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </section>


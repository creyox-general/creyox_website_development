<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="s_hr_job_listing" name="Jobs Listing">
        <section id="jobs_listing" class="s_hr_job_listing cr_font" data-snippet="s_hr_job_listing" data-name="Jobs Listing">
            <t t-set="all_jobs" t-value="request.env['hr.job'].search([])"/>

            <div class="container">
                <!-- Header -->
                <div class="row mb-5 text-center">
                    <div class="col-12" data-aos="fade-up">
                        <h2 class="partner-title fw-bold mb-3">Open <span class="text-gradient">Positions</span></h2>
                        <div class="mx-auto rounded" style="width: 80px; height: 4px; background: linear-gradient(90deg, #4361ee, #4cc9f0);"></div>
                    </div>
                </div>

                <!-- No Jobs Fallback -->
                <div t-if="not all_jobs" class="no_jobs_wrapper text-center">
                    <div class="no_jobs_content">
                        <i class="fa fa-briefcase fa-3x mb-3 text-muted"></i>
                        <h3>No Open Positions at the Moment</h3>
                        <p>We're not currently hiring, but we'd love to hear from you!</p>
                        <a href="/contactus" class="cta-button primary d-inline-flex align-items-center mt-3">
                            <span>Contact Us</span>
                            <i class="fa fa-arrow-right"/>
                        </a>
                    </div>
                </div>

                <t t-else="">
                    <!-- Jobs Grid -->
                    <div class="row g-4">
                        <t t-foreach="all_jobs" t-as="job">
                            <div class="col-lg-4 col-md-6" data-aos="fade-up">
                                <div class="job_card h-100">
                                    <div class="job_card_header">
                                        <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                                            <h3 class="job_title mb-0">
                                                <a t-attf-href="/jobs/detail/#{slug(job)}">
                                                    <span t-field="job.name"/>
                                                </a>
                                            </h3>
                                            <span t-if="not job.website_published" class="unpublished_badge" style="font-size: 0.68rem !important; padding: 2px 6px !important; margin-top: 6px !important;">Unpublished</span>
                                        </div>
                                        <span t-if="job.no_of_recruitment >= 1" class="positions_badge">
                                            <t t-esc="job.no_of_recruitment"/>
                                            <t t-if="job.no_of_recruitment == 1">Position</t>
                                            <t t-else="">Positions</t>
                                        </span>
                                    </div>

                                    <div class="job_card_body">
                                        <div class="job_description" t-esc="job.description or 'No description available'"/>
                                    </div>

                                    <div class="job_card_footer">
                                        <div class="job_meta">
                                            <span t-if="job.address_id" class="job_location">
                                                <i class="fa fa-map-marker me-2"></i>
                                                <span t-field="job.address_id.city"/>
                                            </span>
                                            <span t-if="job.contract_type_id" class="job_type">
                                                <i class="fa fa-suitcase me-2"></i>
                                                <span t-esc="job.contract_type_id.name"/>
                                            </span>
                                            <span class="job_date">
                                                <i class="fa fa-clock-o me-2"></i>
                                                <span t-field="job.write_date" t-options='{"widget": "relative"}'/>
                                            </span>
                                        </div>
                                        <div class="partner-cta-group">
                                            <a t-attf-href="/jobs/detail/#{slug(job)}" class="cta-button primary w-100 justify-content-center d-inline-flex align-items-center">
                                                <span>View Details &amp; Apply</span>
                                                <i class="fa fa-arrow-right ms-2"/>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>

                    <!-- Talent Pool CTA -->
                    <div class="job_listing_cta mt-5 px-4 py-5 text-center rounded-4 border-0" data-aos="fade-up" style="background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 100%);">
                        <div class="row align-items-center">
                            <div class="col-lg-8 text-lg-start mb-4 mb-lg-0">
                                <h3 class="fw-bold mb-2" style="color: #1e293b;">Don't see a role that fits?</h3>
                                <p class="mb-0 text-muted lead" style="font-size: 16px;">We're always looking for talented people to join our team. Submit your resume and we'll reach out when a matching role opens up.</p>
                            </div>
                            <div class="col-lg-4 text-lg-end mt-4">
                                <a href="mailto:info@creyox.com" class="cta-button primary d-inline-flex align-items-center">
                                    <span>Submit Your Resume</span>
                                    <i class="fa fa-arrow-right ms-2"/>
                                </a>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </section>
    </template>
</odoo>

<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="s_erp_cta" name="ERP CTA">
        <section class="erp-cta-section o_wfull" data-snippet="s_erp_cta" data-name="ERP CTA" aria-labelledby="erp-cta-heading">
            <div class="bubble"></div>
            <div class="bubble"></div>
            <div class="bubble"></div>
            <div class="bubble"></div>
            <div class="bubble"></div>

            <div class="container erp-cta-container">
                <div class="erp-cta-row">
                    <!-- Text Block -->
                    <div class="erp-cta-text">
                        <h2 id="erp-cta-heading">
                            <t t-if="o_cta_title" t-esc="o_cta_title"/>
                            <t t-else="">Ready to <span class="highlight">Transform Your Business</span> with ERP?</t>
                        </h2>
                    </div>

                    <!-- Button -->
                    <a t-att-href="o_cta_btn_link or '#erp-demo-form'" class="cta-button light" t-att-title="o_cta_btn_title or 'Schedule Free ERP Demo'"
                       aria-label="Get ERP Demo">
                        <span t-esc="o_cta_btn_text or 'Schedule a Free Demo'"></span>
                        <i class="fas fa-calendar-check ms-2" aria-hidden="true"></i>
                    </a>
                </div>
            </div>
        </section>
    </template>

    <!-- Options -->
    <template id="s_erp_cta_options" inherit_id="website.snippet_options">
        <xpath expr="." position="inside">
            <div data-selector=".erp-cta-section" data-js="ErpCtaOptions" string="ERP CTA">
                <we-input string="Title" data-set-cta-title="" data-no-preview="true"/>
                <we-input string="Button Text" data-set-cta-btn-text="" data-no-preview="true"/>
                <we-input string="Button Link" data-set-cta-btn-link="" data-no-preview="true"/>
            </div>
        </xpath>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="homepage_section9" name="Industry Solutions">
        <!-- Industry Solutions Snippet (Specialist Grid) -->
        <div class="oe_structure">
            <section class="s_specialist_grid py-5 sg-cols-4 bg-white cr_font"
                     data-snippet="s_specialist_grid"
                     data-name="Specialist Grid">
                <div class="container">
                    <div class="section-header text-center mb-5" data-aos="fade-up">

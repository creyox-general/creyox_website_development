<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="s_blog_intro_banner" name="Blog Intro Banner">
        <section class="s_blog_intro_banner blog-intro-banner hero-section-wave cr_font"
                 data-snippet="s_blog_intro_banner"
                 data-name="Blog Intro Banner">
            <div class="container">
                <div class="banner-inner-content">
                    <h1 class="banner-main-title">
                        <t t-if="blog">
                            <t t-esc="blog.name"/>
                        </t>
                        <t t-else="">
                            Our Latest News &amp; Insights
                        </t>
                    </h1>
                    <p class="banner-tagline">
                        <t t-if="blog and blog.subtitle">
                            <t t-esc="blog.subtitle"/>
                        </t>
                        <t t-else="">
                            Stay updated with the latest trends, technologies, and ERP innovations from Creyox Technologies.
                        </t>
                    </p>
                    <nav aria-label="breadcrumb">
                        <ul class="banner-breadcrumbs">
                            <li>
                                <a class="breadcrumb-link" href="/blog">
                                    Blogs
                                    <span class="breadcrumb-separator fa fa-angle-right"></span>
                                </a>
                            </li>
                            <t t-if="blog and blog.tag_ids">
                                <li>
                                    <a class="breadcrumb-link" t-attf-href="/cr/blog/tag/#{slug(blog.tag_ids[:1])}">
                                        <t t-esc="blog.tag_ids[:1].name"/>
                                        <span class="breadcrumb-separator fa fa-angle-right"></span>
                                    </a>
                                </li>
                            </t>
                            <t t-if="blog">
                                <li>
                                    <a class="breadcrumb-current">
                                        <t t-esc="blog.name"/>
                                    </a>
                                </li>
                            </t>
                        </ul>
                    </nav>
                </div>
            </div>
        </section>
    </template>

    <record id="cr_internal_website_theme.s_blog_intro_banner_000_scss" model="ir.asset">
        <field name="name">s_blog_intro_banner 000 SCSS</field>
        <field name="bundle">web.assets_frontend</field>
        <field name="path">cr_internal_website_theme/static/src/snippets/s_blog_intro_banner/000.scss</field>
    </record>
</odoo>

    <template id="custom_snippets_client" inherit_id="website.snippets" name="Custom Snippets">
        <xpath expr="//div[@id='snippet_structure']" position="before">
            <div id="snippet_structure" class="o_panel">
                <div class="o_panel_header">YourHome</div>
                <div class="o_panel_body">

                    <!-- use in homepage section-2 -->
                    <t t-snippet="cr_internal_website_theme.s_milestone_section_template" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <!-- use in homepage section-3 -->
                    <t t-snippet="cr_internal_website_theme.s_erp_pain_points_template" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>


                    <t t-snippet="cr_internal_website_theme.s_trusted_partner_template" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_why_choose_us_template" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_service_showcase" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_kinetic_process" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_specialist_grid" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_erp_comparison" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_feature_mesh" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_benefit_mesh" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_dynamic_snippet_faq" string="FAQs">
                        <keywords>content, faq, questions</keywords>
                    </t>





<!--                    <t t-snippet="cr_internal_website_theme.case_study"-->
<!--                       t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg">-->
<!--                        <keywords>explore, case, studies</keywords>-->
<!--                    </t>-->
<!--                    <t t-snippet="cr_internal_website_theme.explore_clients"-->
<!--                       t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"-->
<!--                       data-drop-in=".oe_structure"-->
<!--                       data-drop-near=".oe_structure > *"/>-->
                    <t t-snippet="cr_internal_website_theme.s_service_intro_banner" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_blog_intro_banner" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>
                       
                    <t t-snippet="cr_internal_website_theme.s_comprehensive_service" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_erp_cta" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_industry_use_cases" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_interactive_cards" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_hr_job_listing" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_process_steps" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_contact_form" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>

                    <t t-snippet="cr_internal_website_theme.s_photo_grid" t-thumbnail="/cr_internal_website_theme/static/src/img/hero_thumb.svg"
                            data-drop-in=".oe_structure"
                       data-drop-near=".oe_structure > *"/>
                </div>
            </div>
        </xpath>
    </template>

</odoo>

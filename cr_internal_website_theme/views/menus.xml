<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="cr_internal_website_theme.homepage"
              inherit_id="website.homepage"
              name="Home">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap">
                <t t-call="cr_internal_website_theme.hero_snippet_template"/>
                <t t-call="cr_internal_website_theme.homepage_section2"/>
                <t t-call="cr_internal_website_theme.homepage_section3"/>
                <t t-call="cr_internal_website_theme.homepage_section4"/>
                <t t-call="cr_internal_website_theme.homepage_section5"/>
                <t t-call="cr_internal_website_theme.homepage_section6"/>
                <t t-call="cr_internal_website_theme.homepage_section7"/>
                <t t-call="cr_internal_website_theme.homepage_section8"/>
                <t t-call="cr_internal_website_theme.expert_snippet_template"/>
                <t t-call="cr_internal_website_theme.homepage_section9"/>
                <div class="oe_structure oe_empty" id="homepage_content"/>

            </div>
        </xpath>
    </template>


    <template id="cr_internal_website_theme.cr_company" name="Company">
        <t t-call="website.layout">
            <t t-set="pageName" t-value="'company'"/>
            <div id="wrap" class="oe_structure oe_empty"/>
        </t>
    </template>

    <!-- Create Company page record -->
    <record id="cr_company_page" model="website.page">
        <field name="is_published">True</field>
        <field name="url">/company</field>
        <field name="track">True</field>
        <field name="view_id" ref="cr_internal_website_theme.cr_company"/>
    </record>

    <!-- Create Company parent menu -->
    <record id="menu_company" model="website.menu">
        <field name="name">Company</field>
        <field name="url">/company</field>
        <field name="sequence" type="int">46</field>
        <field name="page_id" ref="cr_company_page"/>
        <field name="website_id" ref="website.default_website"/>
    </record>


    <!-- About Us -->
    <template id="cr_internal_website_theme.cr_about_us" name="About Us">
        <t t-call="website.layout">
            <t t-set="pageName" t-value="'about_us'"/>
            <t t-call="cr_internal_website_theme.about_us_snippet_section1"/>
            <t t-call="cr_internal_website_theme.about_us_snippet_section2"/>
            <t t-call="cr_internal_website_theme.about_us_snippet_section3"/>
            <t t-call="cr_internal_website_theme.about_us_snippet_section4"/>
                        <t t-call="cr_internal_website_theme.about_us_snippet_section5"/>
        </t>
    </template>

    <record id="cr_about_us_page" model="website.page">
        <field name="is_published">True</field>
        <field name="url">/aboutus</field>
        <field name="track">True</field>
        <field name="view_id" ref="cr_internal_website_theme.cr_about_us"/>
    </record>

    <record id="menu_about_us" model="website.menu">
        <field name="name">About Us</field>
        <field name="url">/aboutus</field>
        <field name="parent_id" ref="cr_internal_website_theme.menu_company"/>
        <field name="sequence" type="int">1</field>
        <field name="page_id" ref="cr_internal_website_theme.cr_about_us_page"/>
        <field name="website_id" ref="website.default_website"/>
    </record>



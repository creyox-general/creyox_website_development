<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_case_study_tree" model="ir.ui.view">
        <field name="name">case.study.tree</field>
        <field name="model">case.study</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="case_study_name"/>
                <field name="is_published"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_case_study_form" model="ir.ui.view">
        <field name="name">case.study.form</field>
        <field name="model">case.study</field>
        <field name="arch" type="xml">
            <form string="Case Study">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="is_published" widget="website_redirect_button"/>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="case_study_name"/>
                        <field name="case_study_short_description" widget="html"/>
                        <field name="case_study_main_page_banner"/>
                        <field name="case_study_detail_description" widget="html"/>
                        <field name="client_challenges" widget="html"/>
                        <field name="our_solution" widget="html"/>
                        <field name="impact" widget="html"/>
                        <field name="client_review" widget="html"/>
                        <field name="active"/>
                    </group>
                    <group name="publishing_details" string="Publishing Options">
                        <field name="author_id"/>
                        <field name="create_date" groups="base.group_no_one"/>
                        <field name="visits"/>
                        <field name="post_date"/>
                        <field name="write_uid"/>
                        <field name="write_date"/>
                    </group>
                    <notebook>
                    <page name="seo" string="SEO" groups="base.group_no_one">
                        <group name="default_opengraph">
                            <field name="website_meta_title" string="Meta Title"/>
                            <field name="website_meta_description" string="Meta Description"/>
                            <field name="website_meta_keywords" string="Meta Keywords" help="Separate every keyword with a comma"/>
                        </group>
                    </page>
                </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_case_study" model="ir.actions.act_window">
        <field name="name">Case Studies</field>
        <field name="res_model">case.study</field>
        <field name="view_mode">tree,form</field>
    </record>

   <menuitem id="menu_case_study_backend"
          name="Case Studies"
          parent="cr_internal_website_theme.menu_creyox"
          action="cr_internal_website_theme.action_case_study"/>

    <!-- Security -->
    <record id="model_case_study_access" model="ir.model.access">
        <field name="name">case.study.access</field>
        <field name="model_id" ref="model_case_study"/>
        <field name="group_id" ref="base.group_user"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>

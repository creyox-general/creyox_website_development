    <!-- Customize Jobs Index Page -->
    <template id="jobs_index_custom" inherit_id="website_hr_recruitment.index" name="Custom Jobs Page">

        <!-- Replace entire wrap -->
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="custom_jobs_page cr_font">

                <!-- Hero Section -->
                <section class="jobs_hero_section">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-8">
                                <h1 class="hero_title">Join Our Team</h1>
                                <p class="hero_subtitle">Discover exciting career opportunities and be part of our growing team</p>
                            </div>
                            <div class="col-lg-4 text-end">
                                <div class="hero_stat_box">
                                    <h2><t t-esc="len(jobs)"/></h2>
                                    <p>Open Positions</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="career_about_section s_comprehensive_service s_trusted_odoo_partner o_layout_reverse cr_font py-5">
                    <div class="container">
                        <!-- Heading Row -->
                        <div class="row mb-5 pb-lg-3" data-aos="fade-up">
                            <div class="col-12 text-center">
                                <h2 class="partner-title mb-3">
                                    Work with <span class="text-gradient">Passion</span>, Build with <span class="text-gradient">Purpose</span>
                                </h2>
                                <div class="mx-auto rounded" style="width: 80px; height: 4px; background: linear-gradient(90deg, #4361ee, #4cc9f0);"></div>
                            </div>
                        </div>

                        <!-- Content Row -->
                        <div class="row align-items-center flex-column flex-lg-row-reverse">
                            <div class="col-lg-6 mb-5 mb-lg-0" data-aos="fade-left">
                                <div class="partner-content-box text-start pe-lg-5">
                                    <p class="partner-description mb-3 w-100">
                                        We’re a team of Odoo enthusiasts building robust ERP solutions, creative websites, and innovative business apps.
                                        At our company, your ideas matter — collaboration and creativity drive everything we do.
                                    </p>
                                    <ul class="partner-description about_list list-unstyled mb-4">
                                        <li class="mb-2"><i class="fa fa-check-circle text-primary me-2"></i> Flexible Work Environment</li>
                                        <li class="mb-2"><i class="fa fa-check-circle text-primary me-2"></i> Continuous Learning</li>
                                        <li class="mb-2"><i class="fa fa-check-circle text-primary me-2"></i> Global Client Exposure</li>
                                    </ul>
                                    
                                    <div class="partner-cta-group mt-3">
                                        <a href="#jobs_listing" class="cta-button primary w-100 w-lg-auto d-inline-flex align-items-center justify-content-center justify-content-lg-start">
                                            <span>Explore Opportunities</span>
                                            <i class="fa fa-arrow-right ms-2" aria-hidden="true"/>
                                        </a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6" data-aos="fade-right">
                                <div class="partner-image-box border-0 bg-transparent d-flex align-items-center justify-content-center" style="box-shadow: none !important;">
                                    <img src="/cr_internal_website_theme/static/src/img/career_team.png" 
                                         alt="Our Team" 
                                         class="img-fluid w-100 rounded-4 shadow-lg" 
                                         style="object-fit: cover; max-height: 400px; height: auto;"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Photo Grid -->
                <t t-call="cr_internal_website_theme.s_photo_grid"/>

                <!-- Jobs Listing -->
                <div class="oe_structure cr_font" id="oe_structure_jobs_listing_page">
                    <t t-call="cr_internal_website_theme.s_hr_job_listing"/>
                </div>


                <!-- How We Hire Section (Process Steps Structure) -->
                <section class="s_process_steps cr_font">
                    <div class="container">
                        <div class="row mb-5 text-center" data-aos="fade-up">
                            <div class="col-12">
                                <h2 class="partner-title display-4 fw-bold">Our <span class="text-gradient">Hiring Process</span></h2>
                                <p class="lead text-muted">A transparent, respectful process designed to help us both find the right fit.</p>
                            </div>
                        </div>

                        <div class="process-steps-wrapper">
                            <!-- Step 1: Apply Online -->
                            <div class="process-step-row row align-items-center mb-5" data-aos="fade-up">
                                <div class="col-lg-6 step-text-col">
                                    <div class="step-card text-card">
                                        <h3 class="step-title">Apply Online</h3>
                                        <p class="step-desc">Submit your application through our careers page. We review every submission carefully and get back to shortlisted candidates within 3–5 business days.</p>
                                        
                                    </div>
                                </div>
                                <div class="col-lg-6 step-image-col">
                                    <div class="step-card image-card">
                                        <img src="/cr_internal_website_theme/static/src/img/step1.jpg" alt="Apply Online" class="img-fluid"/>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 2: Screening Call -->
                            <div class="process-step-row row align-items-center mb-5 flex-row-reverse" data-aos="fade-up">
                                <div class="col-lg-6 step-text-col">
                                    <div class="step-card text-card">
                                        <h3 class="step-title">Screening Call</h3>
                                        <p class="step-desc">A quick 15–20 min call with our HR team to get to know each other, discuss your background, and align expectations around the role and team culture.</p>
                                        
                                    </div>
                                </div>
                                <div class="col-lg-6 step-image-col">
                                    <div class="step-card image-card">
                                        <img src="/cr_internal_website_theme/static/src/img/step2.jpg" alt="Screening Call" class="img-fluid"/>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 3: Technical Round -->
                            <div class="process-step-row row align-items-center mb-5" data-aos="fade-up">
                                <div class="col-lg-6 step-text-col">
                                    <div class="step-card text-card">
                                        <h3 class="step-title">Technical Round</h3>
                                        <p class="step-desc">Demonstrate your skills through a practical assignment or live problem-solving session. We value real-world thinking over rote memorization.</p>
                                        
                                    </div>
                                </div>
                                <div class="col-lg-6 step-image-col">
                                    <div class="step-card image-card">
                                        <img src="/cr_internal_website_theme/static/src/img/step3.jpg" alt="Technical Round" class="img-fluid"/>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 4: Offer & Onboard -->
                            <div class="process-step-row row align-items-center mb-5 flex-row-reverse" data-aos="fade-up">
                                <div class="col-lg-6 step-text-col">
                                    <div class="step-card text-card">
                                        <h3 class="step-title">Offer &amp; Onboard</h3>
                                        <p class="step-desc">Receive your offer letter and begin a structured onboarding journey. We set you up for success from day one with mentorship, tools, and a warm welcome.</p>
                                    
                                    </div>
                                </div>
                                <div class="col-lg-6 step-image-col">
                                    <div class="step-card image-card">
                                        <img src="/cr_internal_website_theme/static/src/img/step5.jpg" alt="Offer and Onboard" class="img-fluid"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Why Join Us Section -->
                <section class="milestone-light-section s_milestone_section cr_font">
                    <div class="milestone-wrapper">
                        <h2 class="milestone-heading">Why Work With Us</h2>
                        <div class="milestone-grid">
                            <!-- Card 1: Growth -->
                            <div class="milestone-card" style="--i:1" role="listitem">
                                <div class="milestone-icon" aria-hidden="true">
                                    <i class="fa fa-rocket"></i>
                                </div>
                                <h3>Growth</h3>
                                <p>Career advancement opportunities</p>
                            </div>
                            <!-- Card 2: Team -->
                            <div class="milestone-card" style="--i:2" role="listitem">
                                <div class="milestone-icon" aria-hidden="true">
                                    <i class="fa fa-users"></i>
                                </div>
                                <h3>Team</h3>
                                <p>Collaborative environment</p>
                            </div>
                            <!-- Card 3: Balance -->
                            <div class="milestone-card" style="--i:3" role="listitem">
                                <div class="milestone-icon" aria-hidden="true">
                                    <i class="fa fa-heart"></i>
                                </div>
                                <h3>Balance</h3>
                                <p>Work-life balance programs</p>
                            </div>
                            <!-- Card 4: Benefits -->
                            <div class="milestone-card" style="--i:4" role="listitem">
                                <div class="milestone-icon" aria-hidden="true">
                                    <i class="fa fa-trophy"></i>
                                </div>
                                <h3>Benefits</h3>
                                <p>Competitive packages</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Connect with us Section -->
                <section class="s_specialist_grid s_odoo_specialists_pillars connect_us_section bg-white">
                    <div class="container">
                        <div class="section-header text-center mb-5" data-aos="fade-up">
                            <h2 class="section-title">Connect With <span class="text-gradient">Us</span></h2>
                            <p class="section-subtitle mt-2">Join our community and stay updated with the latest opportunities.</p>
                        </div>
                        <div class="specialist-grid">
                            <div class="row g-4 justify-content-center">
                                <!-- Card 1: Uplevel your career -->
                                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                                    <div class="specialist-card h-100 text-center align-items-center">
                                        <div class="card-icon mb-4">
                                            <i class="fa fa-user-circle-o fa-4x text-primary"/>
                                        </div>
                                        <h3 class="card-title">Uplevel your career</h3>
                                        <p class="card-text mb-4">Find your next role to thrive and build a better digital world at Creyox.</p>
                                        <div class="partner-cta-group w-100 mt-auto">
                                            <a href="#jobs_listing" class="cta-button primary w-100 justify-content-center d-inline-flex align-items-center">
                                                <span>Search Job</span>
                                                <i class="fa fa-arrow-right ms-2" aria-hidden="true"/>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <!-- Card 2: Join our talent community -->
                                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
                                    <div class="specialist-card h-100 text-center align-items-center">
                                        <div class="card-icon mb-4">
                                            <i class="fa fa-users fa-4x text-primary"/>
                                        </div>
                                        <h3 class="card-title">Join our talent community</h3>
                                        <p class="card-text mb-4">Stay connected for future opportunities that match your expertise and passion.</p>
                                        <div class="partner-cta-group w-100 mt-auto">
                                            <a href="#jobs_listing" class="cta-button primary w-100 justify-content-center d-inline-flex align-items-center">
                                                <span>Submit Resume</span>
                                                <i class="fa fa-arrow-right ms-2" aria-hidden="true"/>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <!-- Card 3: Follow us on LinkedIn -->
                                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
                                    <div class="specialist-card h-100 text-center align-items-center">
                                        <div class="card-icon mb-4">
                                            <i class="fa fa-linkedin-square fa-4x text-primary"/>
                                        </div>
                                        <h3 class="card-title">Follow us on LinkedIn</h3>
                                        <p class="card-text mb-4">Get the latest updates on life at Creyox, our culture, and our growing team.</p>
                                        <div class="partner-cta-group w-100 mt-auto">
                                            <a href="https://in.linkedin.com/company/creyox-technologie-s" target="_blank" class="cta-button primary w-100 justify-content-center d-inline-flex align-items-center">
                                                <span>Follow</span>
                                                <i class="fa fa-arrow-right ms-2" aria-hidden="true"/>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </xpath>
    </template>

</odoo>